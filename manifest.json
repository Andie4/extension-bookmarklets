{
  "manifest_version": 2,
  "name": "Extension A11Y",
  "version": "1.0",
  "description": "Regroupement des bookmarklets disponible sur A11Y.tools.com",
  "icons": { "48": "icon/programmation-web.png" },
  "permissions": ["activeTab"],
  "browser_action": {
    "default_icon": "icon/programmation-web.png",
    "default_title": "A11y-Bookmarklets",
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    "bookmarklets.json",
    "page-extend/my-page.html",
    "page-extend/my-page.js",
    "bookmarklets/listImages.js",
    "bookmarklets/listLinks.js",
    "bookmarklets/listButtons.js",
    "bookmarklets/listTabs.js",
    "bookmarklets/focusIndicator.js",
    "bookmarklets/focusOrder.js",
    "bookmarklets/focusStyle.js",
    "bookmarklets/lostFocusAltert.js",
    "bookmarklets/structureRevealer.js",
    "bookmarklets/groupeFields.js",
    "bookmarklets/checkHeadings.js",
    "bookmarklets/WTFocus.js",
    "bookmarklets/checkNewWindowLinks.js",
    "bookmarklets/visuallyHidden.js",
    "bookmarklets/blackout.js",
    "bookmarklets/clickDeCrapulator.js",
    "bookmarklets/lookUpWCAGSuccessCriteria.js",
    "bookmarklets/lookUpHTMLReference.js",
    "bookmarklets/swatchifyColorRefs.js",
    "bookmarklets/pageColorAnalysis.js",
    "bookmarklets/viewportDetails-2xPixelDensity.js",
    "bookmarklets/viewportDetails-1xPixelDensity.js",
    "bookmarklets/viewportDetails-1-5xPixelDensity.js",
    "bookmarklets/getTableData.js",
    "bookmarklets/navigateLikeScreenReaderUser.js",
    "bookmarklets/nonUnderlinedLinks.js",
    "bookmarklets/suggestAutocompleteValues.js",
    "bookmarklets/liveRegionWatcher.js",
    "bookmarklets/screenReaderSimulation.js",
    "bookmarklets/listThingsWithTitles.js",
    "bookmarklets/attributeStripper.js",
    "bookmarklets/elementStripper.js",
    "bookmarklets/nodeKiller.js",
    "bookmarklets/nodeDuplicator.js",
    "bookmarklets/serialKiller.js",
    "bookmarklets/isolator.js",
    "bookmarklets/selectorSelector.js",
    "bookmarklets/xpath&SourceGetter.js",
    "bookmarklets/getAllLinksInSelectedArea.js",
    "bookmarklets/linkOpener.js",
    "bookmarklets/elementInspector.js",
    "bookmarklets/whiteBlackMode.js",
    "bookmarklets/lightGreyDarkGreyMode.js",
    "bookmarklets/luridMode.js",
    "bookmarklets/outliner.js",
    "bookmarklets/blurEverything.js",
    "bookmarklets/blurEverythingExcept.js",
    "bookmarklets/grayscaleEverything.js",
    "bookmarklets/grayscaleImages.js",
    "bookmarklets/smartInvert.js",
    "bookmarklets/freezeTheDom.js",
    "bookmarklets/unframeIframes.js"
  ]
}
